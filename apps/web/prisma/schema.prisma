generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CampaignStatus {
  draft
  queued
  sending
  paused
  completed
  failed
}

enum RecipientStatus {
  pending
  sent
  opened
  clicked
  bounced
  spam
  unsubscribed
}

enum EngagementType {
  open
  click
  bounce
  spam
  unsubscribe
}

enum RotationStrategy {
  sequential
  random
}

// ─── Models ───────────────────────────────────────────────────────────────────

// Hostname → tenantId routing lookup. NOT tenant-scoped — it is the source of tenant identity.
model TenantDomain {
  id        String   @id @default(uuid())
  domain    String   @unique
  tenantId  String
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model User {
  id             String   @id @default(uuid())
  tenantId       String
  email          String
  password       String   @db.Text
  name           String
  isAdmin        Boolean  @default(false)
  refreshToken   String?  @db.Text
  sessionVersion Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions  Session[]
  templates Template[]
  campaigns Campaign[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Session {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  sessionToken String   @unique @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

// One record per tenant — enforced by @@unique([tenantId]). Use upsert, never create.
model SmtpConfig {
  id        String   @id @default(uuid())
  tenantId  String
  host      String
  port      Int
  secure    Boolean  @default(false)
  username  String
  password  String   @db.Text
  fromEmail String
  fromName  String
  updatedAt DateTime @updatedAt

  @@unique([tenantId])
}

model Template {
  id         String    @id @default(uuid())
  tenantId   String
  userId     String
  name       String
  subject    String
  body       String    @db.Text
  usageCount Int       @default(0)
  openCount  Int       @default(0)
  clickCount Int       @default(0)
  lastUsed   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignTemplates CampaignTemplate[]

  @@index([tenantId, userId])
}

model Campaign {
  id               String         @id @default(uuid())
  tenantId         String
  userId           String
  name             String
  status           CampaignStatus   @default(draft)
  rotationStrategy RotationStrategy @default(sequential)
  totalRecipients  Int              @default(0)
  sentCount        Int            @default(0)
  openCount        Int            @default(0)
  clickCount       Int            @default(0)
  bounceCount      Int            @default(0)
  spamCount        Int            @default(0)
  unsubscribeCount Int            @default(0)
  scheduledFor     DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignTemplates CampaignTemplate[]
  recipients        Recipient[]

  @@index([tenantId, userId])
  @@index([tenantId, status])
}

model CampaignTemplate {
  id         String @id @default(uuid())
  tenantId   String
  campaignId String
  templateId String
  weight     Int    @default(1)
  order      Int    @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([campaignId, templateId])
  @@index([tenantId])
}

model Recipient {
  id         String          @id @default(uuid())
  tenantId   String
  campaignId String
  email      String
  name       String?
  templateId String?
  status     RecipientStatus @default(pending)
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  createdAt  DateTime        @default(now())

  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  engagements Engagement[]

  @@index([tenantId, campaignId])
  @@index([tenantId, status])
}

model Engagement {
  id          String         @id @default(uuid())
  tenantId    String
  recipientId String
  campaignId  String
  type        EngagementType
  url         String?
  ip          String?
  userAgent   String?
  occurredAt  DateTime       @default(now())
  createdAt   DateTime       @default(now())

  recipient Recipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([tenantId, campaignId])
  @@index([tenantId, recipientId])
}
